{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "[cubism_container]:00_Create",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/src/CubismContainer/cubism_container.py",
                "create",
                "--workspace",
                "${workspaceFolder}",
                "--config",
                "${workspaceFolder}/config/config.yaml",
            ],
            "detail": "Dockerコンテナを作成してサーバーを起動する（初回のセットアップや、イメージの内容を更新したいときに）"
        },
        {
            "label": "[cubism_container]:01_Rebuild",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/src/CubismContainer/cubism_container.py",
                "rebuild",
                "--config",
                "${workspaceFolder}/config/config.yaml"
            ],
            "detail": "Dockerイメージを再構築する（イメージの内容を更新したいときに）"
        },
        {
            "label": "[cubism_container]:exec",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/src/CubismContainer/cubism_container.py",
                "exec",
                "--config",
                "${workspaceFolder}/config/config.yaml"
            ],
            "detail": "Dockerの中に入って操作できるコンソール"
        },
        {
            "hide": true,
            "label": "[cubism_container]:stop_server",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/src/CubismContainer/cubism_container.py",
                "stop_server",
                "--config",
                "${workspaceFolder}/config/config.yaml"
            ],
            "detail": "Dockerコンテナ内のサーバーを停止する"
        },
        {
            "label": "[cubism_container]:template",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/src/CubismContainer/cubism_container.py",
                "template",
                "${workspaceFolder}/config",
                "--sdk_archive",
                "archives/CubismSdkForWeb-5-r.5-beta.3.zip",
                "--moc3_file",
                "archives/Resources/Haru/Haru.moc3",
                "--code_directory",
                "src/adapter",
                "--docker_image_name",
                "acting_doll_image",
                "--docker_container_name",
                "Haru",
                "--port_http",
                "8080",
                "--port_websocket",
                "8765",
                "--port_mcp",
                "3001",
                "--port_tts",
                "50021",
                "--token",
                "your_authentication_token_here"
            ],
            "detail": "config.yaml のテンプレートを生成する"
        },
        {
            "hide": true,
            "label": "[update_model_dirs]",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/src/adapter/server/update_model.py",
                "--workspace",
                "${workspaceFolder}/src/adapter",
                "--horizontal",
                "-15.1",
                "--vertical",
                "-28.2",
                "--scale",
                "0.2",
                "--custom"
            ],
            "detail": "src/Cubism/Resources/ 以下のモデルディレクトリを参照するように lappdefine.ts を更新する"
        }
    ]
}
